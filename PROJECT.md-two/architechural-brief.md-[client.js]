function injectTelemetry(htmlContent) {
  const telemetryScript = `
    <script>
      window.onerror = function(message, source, lineno, colno, error) {
        // Forward the runtime crash back to the client/ingress handler to trigger a healing loop
        window.parent.postMessage({
          type: 'IFRAME_RUNTIME_ERROR',
          error: message,
          line: lineno,
          col: colno
        }, '*');
        return true;
      };
    </script>
  `;
  // Append right before the closing body tag
  return htmlContent.replace("</body>", `${telemetryScript}</body>`);
}

