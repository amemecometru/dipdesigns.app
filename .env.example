# webhooks.email -- environment variables. Copy to .env (which is gitignored).
# NEVER commit real keys. Rotate anything that has ever been committed.

# --- backend/main.py (FastAPI identity-only, port 8000) ---
# No longer handles generation -- only signup + key validation.
# The Worker owns all generation + billing (see worker/ section).
BACKEND_ALLOWED_ORIGINS=https://webhooks.email,http://127.0.0.1:8080

# --- ingress/webhook_handler.py (port 8001) ---
INGRESS_API_KEYS=
DESKTOP_FORWARD_URL=http://127.0.0.1:3000
DESKTOP_FORWARD_KEY=REPLACE_ME

# --- receiver.js (desktop bridge, port 3000) ---
RECEIVER_API_KEY=

# --- worker/ (Cloudflare) -- set these as SECRETS via `wrangler secret put` ---
#   wrangler secret put OPENROUTER_API_KEY       # sk-or-v1-... Worker's OpenRouter key
#   wrangler secret put PROXY_SECRET              # server-to-server auth secret
#   wrangler secret put STRIPE_SECRET_KEY         # sk_test_... or sk_live_...
#   wrangler secret put STRIPE_WEBHOOK_SECRET     # whsec_... from Stripe webhook endpoint
#   wrangler secret put GITHUB_CLIENT_ID          # GitHub OAuth App client ID
#   wrangler secret put GITHUB_CLIENT_SECRET      # GitHub OAuth App client secret
#   wrangler secret put GOOGLE_CLIENT_ID          # Google OAuth client ID
#   wrangler secret put GOOGLE_CLIENT_SECRET      # Google OAuth client secret
#   wrangler secret put OAUTH_REDIRECT_URL        # e.g. https://webhooks-email.logiclemonai.workers.dev

# Worker vars (set in wrangler.toml [vars] or as secrets):
# CREDIT_COST=1
# FREE_DAILY_LIMIT=3  # Tier 1 signed-up daily free allowance

# Stripe price IDs (set as Worker vars):
# PRICE_PACK_SMALL=price_xxxx  # 10 credits
# PRICE_PACK_LARGE=price_xxxx  # 50 credits
# PRICE_SUB_PRO=price_xxxx     # monthly subscription
