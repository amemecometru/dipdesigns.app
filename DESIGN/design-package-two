<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Logicllmon.xyz | Conductive Intelligence</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;800&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --base-dark: #0a0e12;
            --copper-raw: #e37e44;
            --copper-glow: #ff9d6a;
            --patina-primary: #3de1d1;
            --patina-dark: #1b4d4a;
            --oxide-bg: #141d1c;
            --trace-dim: rgba(227, 126, 68, 0.15);
            --border-width: 1px;
            --transition: cubic-bezier(0.16, 1, 0.3, 1);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            scrollbar-width: thin;
            scrollbar-color: var(--copper-raw) transparent;
        }

        body {
            background-color: var(--base-dark);
            color: #fff;
            font-family: 'Outfit', sans-serif;
            overflow-x: hidden;
            line-height: 1.6;
        }

        /* --- BACKGROUND ARCHITECTURE --- */
        .patina-texture {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            opacity: 0.15;
            mix-blend-mode: overlay;
            z-index: 9999;
        }

        .canvas-bg {
            position: fixed;
            inset: 0;
            background: 
                radial-gradient(circle at 10% 10%, var(--patina-dark) 0%, transparent 40%),
                radial-gradient(circle at 90% 90%, #2d1b14 0%, transparent 40%);
            opacity: 0.4;
            filter: blur(80px);
            z-index: -1;
        }

        .grid-overlay {
            position: fixed;
            inset: 0;
            background-image: 
                linear-gradient(to right, rgba(61, 225, 209, 0.05) 1px, transparent 1px),
                linear-gradient(to bottom, rgba(61, 225, 209, 0.05) 1px, transparent 1px);
            background-size: 40px 40px;
            z-index: -1;
        }

        /* --- NAVIGATION --- */
        nav.system-nav {
            position: fixed;
            top: 0;
            width: 100%;
            padding: 2rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            z-index: 1000;
            background: linear-gradient(to bottom, var(--base-dark), transparent);
        }

        .brand {
            font-family: 'Space Mono', monospace;
            font-weight: 700;
            font-size: 1.2rem;
            color: var(--copper-raw);
            text-decoration: none;
            letter-spacing: -1px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .brand::before {
            content: '';
            width: 12px;
            height: 12px;
            background: var(--patina-primary);
            box-shadow: 0 0 10px var(--patina-primary);
        }

        .nav-links {
            display: flex;
            gap: 2rem;
        }

        .nav-links a {
            color: #fff;
            text-decoration: none;
            font-family: 'Space Mono', monospace;
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 2px;
            opacity: 0.6;
            transition: 0.3s var(--transition);
        }

        .nav-links a:hover {
            opacity: 1;
            color: var(--patina-primary);
        }

        /* --- REUSABLE COMPONENTS --- */
        .section-tag {
            font-family: 'Space Mono', monospace;
            font-size: 0.7rem;
            color: var(--patina-primary);
            text-transform: uppercase;
            letter-spacing: 4px;
            margin-bottom: 1rem;
            display: block;
        }

        .glitch-text {
            background: linear-gradient(135deg, var(--copper-raw) 0%, var(--patina-primary) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .filament-btn {
            padding: 1rem 2.5rem;
            background: transparent;
            border: 1px solid var(--copper-raw);
            color: var(--copper-raw);
            font-family: 'Space Mono', monospace;
            text-transform: uppercase;
            letter-spacing: 2px;
            cursor: pointer;
            position: relative;
            transition: 0.4s var(--transition);
            overflow: hidden;
        }

        .filament-btn:hover {
            background: var(--copper-raw);
            color: var(--base-dark);
            box-shadow: 0 0 30px var(--trace-dim);
        }

        /* --- 1. HERO PAGE --- */
        section.hero {
            height: 100vh;
            display: flex;
            flex-direction: column;
            justify-content: center;
            padding: 0 10%;
        }

        .hero h1 {
            font-size: clamp(4rem, 10vw, 8rem);
            line-height: 0.85;
            margin-bottom: 2rem;
            font-weight: 800;
        }

        .hero p {
            max-width: 500px;
            font-size: 1.1rem;
            opacity: 0.7;
            margin-bottom: 3rem;
            font-weight: 300;
        }

        /* --- 2. PRODUCT LAYOUT --- */
        section.product {
            padding: 10rem 10%;
            border-top: 1px solid var(--trace-dim);
        }

        .product-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 4rem;
            align-items: center;
        }

        .schema-container {
            position: relative;
            aspect-ratio: 1;
            border: 1px solid var(--trace-dim);
            background: rgba(255,255,255,0.02);
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .schema-node {
            width: 60%;
            height: 60%;
            border: 2px solid var(--copper-raw);
            position: relative;
            animation: pulse 4s infinite;
        }

        @keyframes pulse {
            0%, 100% { transform: scale(1); opacity: 0.5; }
            50% { transform: scale(1.05); opacity: 1; box-shadow: 0 0 50px var(--trace-dim); }
        }

        .trace-line {
            position: absolute;
            background: var(--patina-primary);
            height: 1px;
            width: 100px;
            top: 50%;
            right: -50px;
            box-shadow: 0 0 10px var(--patina-primary);
        }

        /* --- 3. PRICING TEMPLATE --- */
        section.pricing {
            padding: 10rem 10%;
            background: var(--oxide-bg);
        }

        .pricing-tier-wrapper {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 2rem;
            margin-top: 4rem;
        }

        .tier-card {
            padding: 3rem 2rem;
            border: 1px solid var(--trace-dim);
            background: var(--base-dark);
            position: relative;
            transition: 0.4s var(--transition);
        }

        .tier-card:hover {
            border-color: var(--patina-primary);
            transform: translateY(-10px);
        }

        .tier-card.featured {
            border-color: var(--copper-raw);
        }

        .tier-card.featured::after {
            content: 'HIGH_VOLTAGE';
            position: absolute;
            top: 0;
            right: 20px;
            transform: translateY(-50%);
            background: var(--copper-raw);
            color: var(--base-dark);
            font-family: 'Space Mono', monospace;
            font-size: 0.6rem;
            padding: 2px 8px;
            font-weight: 700;
        }

        .tier-card h3 {
            font-family: 'Space Mono', monospace;
            font-size: 1.5rem;
            margin-bottom: 0.5rem;
        }

        .price {
            font-size: 3rem;
            font-weight: 800;
            margin-bottom: 2rem;
            display: flex;
            align-items: baseline;
        }

        .price span {
            font-size: 1rem;
            opacity: 0.5;
            font-weight: 400;
        }

        .tier-features {
            list-style: none;
            margin-bottom: 3rem;
        }

        .tier-features li {
            font-family: 'Space Mono', monospace;
            font-size: 0.8rem;
            padding: 0.75rem 0;
            border-bottom: 1px solid rgba(255,255,255,0.05);
            display: flex;
            justify-content: space-between;
        }

        .tier-features li::before {
            content: '>';
            color: var(--patina-primary);
        }

        /* --- 4. DOCS PAGE --- */
        section.docs {
            padding: 5rem 10%;
            display: flex;
            gap: 4rem;
        }

        .docs-sidebar {
            width: 250px;
            flex-shrink: 0;
            position: sticky;
            top: 100px;
            height: fit-content;
        }

        .docs-nav-group {
            margin-bottom: 2.5rem;
        }

        .docs-nav-title {
            font-family: 'Space Mono', monospace;
            font-size: 0.7rem;
            color: var(--copper-raw);
            margin-bottom: 1rem;
            display: block;
            text-transform: uppercase;
        }

        .docs-nav-links {
            list-style: none;
        }

        .docs-nav-links li a {
            display: block;
            padding: 0.5rem 0;
            color: #fff;
            text-decoration: none;
            font-size: 0.9rem;
            opacity: 0.5;
            transition: 0.3s;
        }

        .docs-nav-links li a:hover, .docs-nav-links li a.active {
            opacity: 1;
            color: var(--patina-primary);
            padding-left: 10px;
        }

        .docs-content {
            flex-grow: 1;
            max-width: 800px;
        }

        .docs-content h2 {
            font-size: 2.5rem;
            margin-bottom: 2rem;
        }

        .code-block {
            background: #000;
            padding: 2rem;
            border-left: 3px solid var(--copper-raw);
            font-family: 'Space Mono', monospace;
            font-size: 0.85rem;
            margin: 2rem 0;
            position: relative;
            overflow: hidden;
        }

        .code-block::after {
            content: 'JSON_SCHEMA';
            position: absolute;
            top: 0;
            right: 0;
            background: var(--trace-dim);
            color: var(--copper-raw);
            font-size: 10px;
            padding: 4px 8px;
        }

        /* --- DECORATIVE COORDS --- */
        .coord-footer {
            padding: 4rem 10%;
            font-family: 'Space Mono', monospace;
            font-size: 0.7rem;
            color: var(--patina-dark);
            display: flex;
            justify-content: space-between;
            border-top: 1px solid var(--trace-dim);
        }

        /* --- MOBILE RESPONSIVENESS --- */
        @media (max-width: 768px) {
            .product-grid { grid-template-columns: 1fr; }
            section.docs { flex-direction: column; }
            .docs-sidebar { width: 100%; position: relative; top: 0; }
            .hero h1 { font-size: 3.5rem; }
            nav.system-nav { padding: 1.5rem; }
            .nav-links { display: none; }
        }
    </style>
</head>
<body>

    <svg class="patina-texture">
        <filter id="noiseFilter">
            <feTurbulence type="fractalNoise" baseFrequency="0.6" numOctaves="3" stitchTiles="stitch"/>
            <feColorMatrix type="saturate" values="0"/>
        </filter>
        <rect width="100%" height="100%" filter="url(#noiseFilter)"/>
    </svg>

    <div class="grid-overlay"></div>
    <div class="canvas-bg"></div>

    <nav class="system-nav">
        <a href="#" class="brand">LOGICLLMON.XYZ</a>
        <div class="nav-links">
            <a href="#product">Core</a>
            <a href="#pricing">Voltage</a>
            <a href="#docs">Schema</a>
            <a href="#" style="color: var(--copper-raw);">Connect_</a>
        </div>
    </nav>

    <!-- LANDING PAGE -->
    <section class="hero">
        <span class="section-tag">INIT_SEQUENCE_001</span>
        <h1 class="glitch-text">CONDUCTIVE<br>LOGIC</h1>
        <p>The first liquid-metal logic framework for hyper-scalable neural architectures. Oxidize your legacy systems and rebuild in pure copper-grade efficiency.</p>
        <div>
            <button class="filament-btn">Execute Protocol</button>
        </div>
    </section>

    <!-- PRODUCT LAYOUT -->
    <section class="product" id="product">
        <div class="product-grid">
            <div class="schema-container">
                <div class="schema-node">
                    <div class="trace-line"></div>
                    <div class="trace-line" style="transform: rotate(90deg); top: -50px; right: 50%;"></div>
                    <div class="trace-line" style="transform: rotate(-45deg); top: 80%; right: -20px;"></div>
                </div>
            </div>
            <div class="product-info">
                <span class="section-tag">MODULE_DYNAMICS</span>
                <h2>Sub-Atomic Connectivity</h2>
                <p style="margin: 2rem 0; opacity: 0.8;">Our proprietary filament architecture allows for zero-latency data transfer between disparate logic nodes. Unlike traditional fiber, Logicllmon utilizes patina-stabilized copper paths.</p>
                <div class="conductive-path" style="margin-top: 2rem;">
                    <div style="font-family: 'Space Mono', monospace; font-size: 0.8rem; border-left: 2px solid var(--patina-primary); padding-left: 1rem;">
                        <span style="color: var(--patina-primary);">[01]</span> PATINA_ENCRYPTION<br>
                        <span style="color: var(--patina-primary);">[02]</span> OXIDE_RESISTANCE_CTRL<br>
                        <span style="color: var(--patina-primary);">[03]</span> FILAMENT_SCALING
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- PRICING TEMPLATE -->
    <section class="pricing" id="pricing">
        <div style="text-align: center; max-width: 600px; margin: 0 auto;">
            <span class="section-tag">ENERGY_CONSUMPTION</span>
            <h2>Select Your Voltage</h2>
        </div>

        <div class="pricing-tier-wrapper">
            <!-- Tier 1 -->
            <div class="tier-card">
                <h3>GROUND</h3>
                <div class="price">$0<span>/mo</span></div>
                <ul class="tier-features">
                    <li>128 Conductive Nodes</li>
                    <li>Basic Patina Filter</li>
                    <li>Community Schema</li>
                </ul>
                <button class="filament-btn" style="width: 100%;">Initialize</button>
            </div>

            <!-- Tier 2 -->
            <div class="tier-card featured">
                <h3>FILAMENT</h3>
                <div class="price">$49<span>/mo</span></div>
                <ul class="tier-features">
                    <li>1024 Conductive Nodes</li>
                    <li>Glow-State Priority</li>
                    <li>Advanced Trace Logs</li>
                </ul>
                <button class="filament-btn" style="width: 100%; background: var(--copper-raw); color: var(--base-dark);">Overload</button>
            </div>

            <!-- Tier 3 -->
            <div class="tier-card">
                <h3>CORE_UNIT</h3>
                <div class="price">$199<span>/mo</span></div>
                <ul class="tier-features">
                    <li>Unlimited Filaments</li>
                    <li>Neural Oxidization</li>
                    <li>Hardware Handshake</li>
                </ul>
                <button class="filament-btn" style="width: 100%;">Establish</button>
            </div>
        </div>
    </section>

    <!-- DOCS PAGE -->
    <section class="docs" id="docs">
        <aside class="docs-sidebar">
            <div class="docs-nav-group">
                <span class="docs-nav-title">Fundamentals</span>
                <ul class="docs-nav-links">
                    <li><a href="#" class="active">Introduction</a></li>
                    <li><a href="#">Circuit Setup</a></li>
                    <li><a href="#">Voltage Control</a></li>
                </ul>
            </div>
            <div class="docs-nav-group">
                <span class="docs-nav-title">Architecture</span>
                <ul class="docs-nav-links">
                    <li><a href="#">Node Geometry</a></li>
                    <li><a href="#">Patina Layering</a></li>
                    <li><a href="#">Trace Routing</a></li>
                </ul>
            </div>
        </aside>

        <main class="docs-content">
            <span class="section-tag">DOC_V_0.44</span>
            <h2>Routing the Filament</h2>
            <p>To begin a conductive session, you must first define your node coordinates within the Logicllmon framework. The following schema demonstrates a basic ternary connection between three core units.</p>
            
            <div class="code-block">
{
  "protocol": "CONDUCTIVE_V1",
  "origin": "CORE_NODE_01",
  "target": "CORE_NODE_02",
  "voltage": "4.2V",
  "resistance": "minimal",
  "oxidize": true
}
            </div>

            <p>Once the handshake is verified, the <code>patina-texture</code> will automatically apply to the logic gate, ensuring no data leakage through the insulating layers.</p>
        </main>
    </section>

    <footer class="coord-footer">
        <div>
            SYSTEM_STATUS: <span style="color: var(--patina-primary);">ACTIVE</span><br>
            VERSION: LOGIC_LLMON_X.Y.Z
        </div>
        <div style="text-align: right;">
            LAT: 45.32.11 // LONG: 12.00.94<br>
            © 2024 LOGICLLMON LABS
        </div>
    </footer>

    <script>
        // Interactive background follow
        document.addEventListener('mousemove', (e) => {
            const x = (e.clientX / window.innerWidth) * 100;
            const y = (e.clientY / window.innerHeight) * 100;
            document.querySelector('.canvas-bg').style.background = `
                radial-gradient(circle at ${x}% ${y}%, var(--copper-glow) 0%, transparent 15%),
                radial-gradient(circle at 10% 10%, var(--patina-dark) 0%, transparent 40%),
                radial-gradient(circle at 90% 90%, #2d1b14 0%, transparent 40%)
            `;
        });

        // Smooth scroll for nav
        document.querySelectorAll('.nav-links a').forEach(anchor => {
            anchor.addEventListener('click', function(e) {
                e.preventDefault();
                const targetId = this.getAttribute('href');
                if(targetId === '#') return;
                document.querySelector(targetId).scrollIntoView({
                    behavior: 'smooth'
                });
            });
        });

        // Entry animation observer
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.style.opacity = '1';
                    entry.target.style.transform = 'translateY(0)';
                }
            });
        }, { threshold: 0.1 });

        document.querySelectorAll('section').forEach(section => {
            section.style.opacity = '0';
            section.style.transform = 'translateY(20px)';
            section.style.transition = 'all 1s var(--transition)';
            observer.observe(section);
        });
    </script>
</body>
</html>